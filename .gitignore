# ========================
# KeySpy .gitignore
# ========================

# ---- Dependencies ----
node_modules/
.pnpm-store/

# ---- Next.js ----
.next/
out/

# ---- Build ----
build/
dist/
*.tsbuildinfo

# ---- Environment / Secrets ----
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.p12
*.pfx
*.jks

# ---- Credentials & Tokens ----
cookies.txt
credentials.json
service-account*.json
*.credentials

# ---- Database ----
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ---- OS / Editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Debug Logs ----
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- TypeScript ----
next-env.d.ts

# ---- Screenshots & Test Artifacts ----
test-screens/

# ---- Large Binaries (gitleaks > 20MB) ----
tools/gitleaks/gitleaks.exe
tools/gitleaks/gitleaks
